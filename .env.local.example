# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Pricing tiers (Stripe)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# Resend
RESEND_API_KEY=re_...

# App
# Local dev: http://localhost:3000   Production: https://coolbid.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Gmail API)
# Local dev: http://localhost:3000/api/auth/gmail/callback
# Production: https://coolbid.app/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# Google Document AI
GOOGLE_DOCUMENT_AI_CREDENTIALS=  # base64-encoded service account JSON
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=  # projects/{id}/locations/{loc}/processors/{proc}

# Quote Miner
CRON_SECRET=
OAUTH_STATE_SECRET=
